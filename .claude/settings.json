{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "! command -v damask >/dev/null 2>&1 || damask peek",
            "type": "command"
          }
        ],
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "if command -v damask >/dev/null 2>&1; then damask briefing; else echo 'This repo has a damask knowledge graph (.damask/) shared across agent sessions. Install the damask CLI to inherit it: cargo install damask'; fi",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "! command -v damask >/dev/null 2>&1 || damask harvest",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "! command -v damask >/dev/null 2>&1 || damask peek",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(damask *)",
      "Bash(cargo build *)",
      "Bash(cargo test *)",
      "Bash(cargo run *)"
    ]
  }
}