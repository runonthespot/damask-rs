{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "damask peek",
            "type": "command"
          }
        ],
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "damask briefing",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "damask harvest",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "damask peek",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(damask *)",
      "Bash(cargo build *)",
      "Bash(cargo test *)",
      "Bash(cargo run *)"
    ]
  }
}